{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "include": [
      "resources/js/**/*.js",
      "!resources/js/*.min.js",
      "!resources/js/jquery*.js",
      "!resources/js/bootstrap*.js",
      "!resources/js/datastar.min.js"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": { "recommended": false },
      "complexity": { "recommended": false },
      "correctness": { "recommended": false },
      "nursery": { "recommended": false },
      "performance": { "recommended": false },
      "security": { "recommended": false },
      "style": { "recommended": false },
      "suspicious": {
        "recommended": false,
        "noDoubleEquals": "error"
      }
    }
  },
  "formatter": {
    "enabled": false
  }
}
