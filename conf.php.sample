///////////////////////////////////////////////////////////////////////////
// ESSENTIAL SETTINGS - these must be filled in for the system to run at all:
///////////////////////////////////////////////////////////////////////////


// Name of the mysql database, eg jethro
define('DB_DATABASE', '');

// Username and password of the mysql account with which to access the mysql database
define('DB_USERNAME', '');
define('DB_PASSWORD', '');

// Advanced: If your Jethro PHP-FPM runs as a dedicated OS user ('jethro'), you can enable socket-based authentication in MySQL:
//     create user if not exists 'jethro'@'localhost' identified with unix_socket;
// then use socket-based auth for Jethro by specifying DB_DSN instead of DB_PASSWORD as follows:
// define('DB_USERNAME', 'jethro');
// define('DB_DSN', "mysql:dbname=jethro");

// The URL jethro will be running at. Only needs to be set if Jethro is running behind a proxy without
// X-Forwarded-Proto + X-Forwarded-Host, or running scripts/task_reminder.php, where the base URL cannot be inferred
// define('BASE_URL', 'https://example.com/jethro/');

// Whether the system must be accessed by HTTPS.
// If this is true, the BASE_URL above must begin with https://
// No longer used - Jethro will run wherever it finds itself.
// define('REQUIRE_HTTPS', FALSE);

///////////////////////////////////////////////////////////////////////////
// OPTIONAL DATABASE SETTINGS -
// you can use these for more precise control of your mysql database
///////////////////////////////////////////////////////////////////////////

// Username and password of the mysql account that the MEMBERS area of Jethro should
// use. Optional. This can be used to add an extra layer of security by only granting
// access to the tables needed for members area features.
define('DB_MEMBERS_USERNAME', '');
define('DB_MEMBERS_PASSWORD', '');

// Username and password of the mysql account that the PUBLIC area of Jethro should
// use. Optional. This can be used to add an extra layer of security by only granting
// access to the tables needed for public  area features.
define('DB_PUBLIC_USERNAME', '');
define('DB_PUBLIC_PASSWORD', '');

// Server on which mysql is running - usually localhost
define('DB_HOST', 'localhost');

// Database type - usually mysql.
define('DB_TYPE', 'mysql');

///////////////////////////////////////////////////////////////////////////
// 2-FACTOR AUTH SETTINGS - These can also be configured in the web interface,
// but you may want to define them here to lock them down.
///////////////////////////////////////////////////////////////////////////
// Whether to 2FA. Setting to false always turned it off. Setting to true still requires other parameters defined for 2FA to be applied.
define('2FA_ENABLED', true);

// Allow users to tick a box to bypass 2-factor auth for this many days
//define('2FA_TRUST_DAYS','30');

// Sender ID for 2-factor auth SMS messages. Mirrors SMS_SENDER.
//define('2FA_SENDER_ID','Jethro');

// Require 2-factor auth for users that hold these permissions
//define('2FA_REQUIRED_PERMS','2147483647,48'); // SYSADMIN,VIEWNOTE

// Require 2-factor auth even for accounts with group/congregation restrictions?
//define('2FA_EVEN_FOR_RESTRICTED_ACCTS', false);

///////////////////////////////////////////////////////////////////////////
// SMS SETTINGS - These can also be configured in the web interface,
// but you may want to define them here to avoid making credentials visible.
///////////////////////////////////////////////////////////////////////////

// Fully qualified class name or short key of the SMS provider to use.
// If not defined here, the 'SMS_PROVIDER' setting in the admin System Configuration
// page is used (default: 'Auto-detect'). Short keys: '5centsmsv5', 'cellcast', 'smsbroadcast'.
//   \Sms\Providers\FiveCentSmsV5Provider::class    — https://5centsms.com.au modern (v5) JSON API
//   \Sms\Providers\CellcastSmsProvider::class      — https://cellcast.com JSON API
//   \Sms\Providers\SmsBroadcastSmsProvider::class  — https://smsbroadcast.com.au API (works but not recommended)
//   \Sms\Providers\FiveCentSmsV4Provider::class    — https://5centsms.com.au legacy (v4) API (deprecated — use v5)
//   \Sms\Providers\TemplateSmsProvider::class      — generic HTTP POST template gateway (use only if you know what you're doing)
// define('SMS_PROVIDER', '');

// =====================================================================
// 5CentSMS v5 (5centsms.com.au) — modern JSON API
//   Supports scheduling, cancellation, delivery status polling, and balance.
// =====================================================================

// API key ID from https://www.5centsms.com.au/dashboard/api (required)
// define('SMS_5CENTSMS_APIKEY_ID', '');

// API key secret from https://www.5centsms.com.au/dashboard/api (required)
// define('SMS_5CENTSMS_APIKEY', '');

// API base URL (optional; defaults to https://www.5centsms.com.au/api/v5)
// define('SMS_5CENTSMS_URL', '');

// Block sends when the account balance is too low (optional)
// define('SMS_BALANCE_ENFORCED', true);

// =====================================================================
// Cellcast (cellcast.com) — JSON API
//   Supports scheduling, cancellation, and delivery status polling.
// =====================================================================

// API bearer token from your Cellcast dashboard (required)
// define('SMS_CELLCAST_APIKEY', '');

// API base URL (optional; defaults to https://api.cellcast.com)
// define('SMS_CELLCAST_URL', '');

// =====================================================================
// SMS Broadcast (smsbroadcast.com.au)
//   Supports scheduling; does NOT support cancellation or delivery status polling.
// =====================================================================

// API username (required)
// define('SMS_SMSBROADCAST_USERNAME', '');

// API password (required)
// define('SMS_SMSBROADCAST_PASSWORD', '');

// API endpoint URL (optional; defaults to https://www.smsbroadcast.com.au/api-adv.php)
// define('SMS_SMSBROADCAST_URL', '');

// =====================================================================
// Common SMS settings (apply to all providers)
// =====================================================================

// The maximum SMS length users are allowed to send.  160 chars is usually a one-part SMS.
// define('SMS_MAX_LENGTH', 160);

// If true, SMS HTTP requests and responses are logged to the PHP error log (useful for debugging).
// define('SMS_VERBOSE', false);

// If true, SMSes are not actually sent (dry-run mode).
// define('SMS_TESTMODE', true);

// Delay in seconds applied to all SMS sends.  When unset, a 30-second cool-off
// is applied automatically, giving the user a window to realise a mistake.
// Set to 0 to disable.
// define('SMS_SEND_COOLOFF', 30);

// Comma-separated sender options for the SMS dropdown.  Recognised tokens:
//   _SENDER_IDS_  — expands to every sender ID your SMS provider reports
//   _USER_MOBILE_ — expands to the current user's mobile number
// Defaults to '_SENDER_IDS_,_USER_MOBILE_' when not defined.
// Literal values (e.g. 'StBarnabas') are always included as-is.
// Example: define('SMS_SENDER_OPTIONS', 'StBarnabas,_SENDER_IDS_,_USER_MOBILE_');
// Set to an empty string to disable all Sender ID lookup:
//   define('SMS_SENDER_OPTIONS', '');
// define('SMS_SENDER_OPTIONS', '');

// Hardcode the sender (Sender ID or mobile number) for all SMS messages.
// Use '_USER_MOBILE_' to use the current user's mobile number.
// define('SMS_SENDER', 'MyChurch');

// Default sender selected in the SMS sender dropdown (Sender ID or '_USER_MOBILE_').
// define('SMS_SENDER_DEFAULT', ''); // blank = first option in SMS_SENDER_OPTIONS

// A file to log who has sent SMSes (optional). JSONP format.
// define('SMS_SEND_LOGFILE', '');

// =====================================================================
// UI and behaviour settings
// =====================================================================

// Whether to allow Unicode characters (e.g. emoji) in SMS messages. Be aware that even a single unicode character doubles the cost for >70 char messages.
// 1 = allow Unicode freely
// 0 = disable Unicode entirely — only GSM 03.38 characters are allowed and
//     non-GSM characters will prevent the form from submitting.
// 'when_free' = allow Unicode for messages ≤70 chars (single UCS-2 segment).
//     Longer messages with non-GSM chars will be blocked.
// define('SMS_UNICODE_PERMITTED', 'when_free');

// Low-balance alert: trigger a notification when the SMS account balance drops below this amount.
// Set to 0 to disable.
// define('SMS_BALANCE_LOW_THRESHOLD', 10.00);

// Person ID of the staff member to notify when SMS balance drops below SMS_BALANCE_LOW_THRESHOLD.
// define('SMS_BALANCE_LOW_NOTIFICANT', 0);

// =====================================================================
// Legacy v4 / template-based gateway settings
// Only needed if using FiveCentSmsV4Provider, TemplateSmsProvider, or a
// custom HTTP-template gateway.  Most users should use one of the
// provider-specific sections above instead.
// =====================================================================

// URL of the SMS gateway to send SMSes through
// define('SMS_HTTP_URL', '');

// Template for the headers of the HTTP POST request Jethro will send to the SMS gateway.
// Some SMS gateways use headers for authentication.
// Example: define('SMS_HTTP_HEADER_TEMPLATE', "User: me@example.com\r\nApi-Key: MyAPIKey\r\n");
// define('SMS_HTTP_HEADER_TEMPLATE', '');

// Template for the body of the HTTP POST request Jethro will send to the SMS gateway.
// Can include the following keywords:
//   _MESSAGE_ - text message to send
//   _RECIPIENTS_COMMAS_ - recipient mobile numbers separated by commas
//   _RECIPIENTS_NEWLINES_ - recipient mobile numbers separated by newlines
//   _RECIPIENTS_ARRAY_ - recipient mobile numbers as an array.  See SMS_RECIPIENT_ARRAY_PARAMETER.
//   _RECIPIENTS_INTERNATIONAL_COMMAS_ - internationalised recipient numbers separated by commas
//                                      (see SMS_LOCAL_PREFIX and SMS_INTERNATIONAL_PREFIX below)
//   _RECIPIENTS_INTERNATIONAL_NEWLINES_ - recipient numbers separated by newlines
//   _RECIPIENTS_INTERNATIONAL_ARRAY_ - recipient numbers as an array
//   _USER_MOBILE_ - mobile number of the current Jethro user (for use as sender)
//   _USER_EMAIL_ - email address of the current Jethro user
// define('SMS_HTTP_POST_TEMPLATE', '');

// Base name for the _RECIPIENTS_ARRAY_ keyword available above.
// E.g. set this to "number" to get number[]=0412333444&number[]=0413555666 etc
// define('SMS_RECIPIENT_ARRAY_PARAMETER', 'number');

// Regex to use to detect success message from the SMS server for each recipient.
// Optional. Omit slash delimiters at start and end. Leave blank to ignore response.
// Keywords available:
//   _RECIPIENT_ - recipient number in raw format
//   _RECIPIENT_INTERNATIONAL_ - recipient number in international format
//                              (see SMS_LOCAL_PREFIX and SMS_INTERNATIONAL_PREFIX below)
// define('SMS_HTTP_RESPONSE_OK_REGEX', '');

// Regex to detect an overall error response from the API server (e.g. bad credentials).
// Optional.  Omit slash delimiters at start and end. Leave blank to ignore response.
// define('SMS_HTTP_RESPONSE_ERROR_REGEX', '');

// Regex with a capture group to extract the remote message ID from the response.
// The first capture group is stored as the remote message ID.
// define('SMS_HTTP_RESPONSE_ID_REGEX', '');

// Balance endpoint URL for the SMS gateway (optional).
// define('SMS_HTTP_URL_BALANCE', '');

// Local prefix used in the mobile numbers stored in Jethro.
// E.g. '0' — stripped before prepending the international prefix.
// define('SMS_LOCAL_PREFIX', '0');

// International prefix, which replaces the local prefix to form an international-format number.
// E.g. '61' for Australia.
// define('SMS_INTERNATIONAL_PREFIX', '61');

